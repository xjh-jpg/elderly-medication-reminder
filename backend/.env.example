# 复制此文件为 .env 并填入真实值
# Railway 部署时直接在环境变量面板填写，不需要这个文件

# 数据库配置（Railway 会自动注入以下变量）
DB_HOST=your-railway-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=railway

# JWT配置（自己改一个复杂的密钥）
JWT_SECRET=change_this_to_a_strong_random_secret_key
JWT_EXPIRES_IN=7d

# 端口（Railway 会自动注入 PORT，不用改）
PORT=3000

# 跨域配置（填你的 Vercel 前端地址）
CORS_ORIGIN=https://your-frontend.vercel.app
